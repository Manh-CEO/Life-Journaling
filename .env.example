# Application
APP_PORT=8080
APP_ENV=development

# Database (PostgreSQL / Supabase)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=life_journaling
DB_SSL_MODE=disable

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=prompts@yourdomain.com

# Gemini (LLM)
GEMINI_API_KEY=your-gemini-api-key

# QStash (Cron)
QSTASH_SIGNING_KEY=your-qstash-signing-key

# Cloudflare (Inbound Email Webhook)
CF_WEBHOOK_SECRET=your-cloudflare-secret
